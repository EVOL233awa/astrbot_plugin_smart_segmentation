{
  "enabled": {
    "type": "bool",
    "description": "启用智能分段",
    "hint": "关闭后插件不会预分段、替换首段或补发剩余分段。",
    "default": true
  },
  "provider_id": {
    "type": "string",
    "description": "分段模型 Provider ID",
    "hint": "留空使用当前会话正在使用的聊天模型；也可在此选择一个小模型专门用于分段。",
    "default": "",
    "_special": "select_provider"
  },
  "style": {
    "type": "string",
    "description": "分段风格",
    "hint": "natural 更像普通聊天；conservative 更少分段；active 更短更活泼。",
    "default": "natural",
    "options": [
      "natural",
      "conservative",
      "active"
    ]
  },
  "min_length": {
    "type": "int",
    "description": "最小分段长度",
    "hint": "回复文本短于该长度时不调用分段模型。",
    "default": 15,
    "slider": {
      "min": 0,
      "max": 200,
      "step": 1
    }
  },
  "max_segments": {
    "type": "int",
    "description": "最大分段数量",
    "hint": "用于限制单次回复最多拆成多少条，避免刷屏。",
    "default": 8,
    "slider": {
      "min": 1,
      "max": 20,
      "step": 1
    }
  },
  "temperature": {
    "type": "float",
    "description": "分段模型温度",
    "default": 0.3,
    "slider": {
      "min": 0,
      "max": 2,
      "step": 0.1
    }
  },
  "max_tokens": {
    "type": "int",
    "description": "分段模型最大输出 token",
    "default": 600,
    "slider": {
      "min": 64,
      "max": 4096,
      "step": 32
    }
  },
  "timeout_seconds": {
    "type": "float",
    "description": "分段模型超时时间（秒）",
    "hint": "超过该时间会跳过本次分段，直接发送原回复。",
    "default": 12.0,
    "slider": {
      "min": 1,
      "max": 60,
      "step": 0.5
    }
  },
  "delay_base": {
    "type": "float",
    "description": "补发基础延迟（秒）",
    "default": 0.35,
    "slider": {
      "min": 0,
      "max": 5,
      "step": 0.05
    }
  },
  "delay_per_char": {
    "type": "float",
    "description": "按字符增加延迟（秒/字符）",
    "default": 0.015,
    "slider": {
      "min": 0,
      "max": 0.2,
      "step": 0.005
    }
  },
  "delay_max": {
    "type": "float",
    "description": "单段最大补发延迟（秒）",
    "default": 1.2,
    "slider": {
      "min": 0,
      "max": 10,
      "step": 0.1
    }
  }
}
